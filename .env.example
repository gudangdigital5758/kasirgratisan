# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
# Kosongkan untuk menonaktifkan analytics (mis. di development).
VITE_GA_MEASUREMENT_ID=

# === Profitku Cloud API (Cloudflare Worker) ===
# Local Worker: http://127.0.0.1:8787
# Production:   https://api.profitku.my.id
VITE_AUTH_API_URL=http://127.0.0.1:8787

# Google OAuth Web Client ID (xxxx.apps.googleusercontent.com).
# Dipakai Google Identity Services / native Social Login → ID token,
# lalu ditukar ke sesi Supabase Auth (signInWithIdToken).
VITE_GOOGLE_CLIENT_ID=

# === Supabase Auth (wajib untuk cloud production) ===
# Project URL + anon key (aman di client). Service role HANYA di Worker.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=

# OneSignal App ID untuk push notification.
# Kosongkan untuk menonaktifkan push notification.
VITE_ONESIGNAL_APP_ID=
